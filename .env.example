# Jack The Shadow — Environment Configuration
# Credentials are managed via /login command (stored in ~/.jshadow/credentials.json)
# You can also set them here as fallback:
# CLOUDFLARE_ACCOUNT_ID=your_account_id_here
# CLOUDFLARE_API_TOKEN=your_api_token_here

# Defaults (optional)
JSHADOW_DEFAULT_MODEL=@cf/openai/gpt-oss-120b
JSHADOW_LANG=en
JSHADOW_LOG_LEVEL=DEBUG
